  m_Script: {fileID: 11500000, guid: c0afd7c2df802a24b88f0f5a1f34ef43, type: 3}
  m_Name: Node_Veil_01_Reveal
  m_EditorClassIdentifier: Assembly-CSharp::DialogueNode
  nodeId: Node_Veil_01_Reveal
  lines:
  - speaker: Veil
    text: You walked far, mother.
    voice: {fileID: 0}
    extraDelay: 0
  - speaker: Veil
    text: Far enough that I no longer have to whisper.
    voice: {fileID: 0}
    extraDelay: 0
  - speaker: Irai
    text: You took her shape. My mother's voice.
    voice: {fileID: 0}
    extraDelay: 0
  - speaker: Veil
    text: I took the only voice you ever obeyed.
    voice: {fileID: 0}
    extraDelay: 0
