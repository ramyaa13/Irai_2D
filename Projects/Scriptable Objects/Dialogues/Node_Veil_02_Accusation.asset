  nodeId: Node_Veil_02_Accusation
  lines:
  - speaker: Veil
    text: Look at him. Sleeping. Trusting.
    voice: {fileID: 0}
    extraDelay: 0
  - speaker: Veil
    text: He does not yet know what you are.
    voice: {fileID: 0}
    extraDelay: 0
  - speaker: Veil
    text: A woman who left. A woman who broke.
    voice: {fileID: 0}
    extraDelay: 0
  - speaker: Veil
    text: A woman they were right to cast out.
    voice: {fileID: 0}
    extraDelay: 0
  choices:
  - choiceId: veil_defy
    label: You wear her face. You are not her.
    responseText: You wear her face. You are not her.
